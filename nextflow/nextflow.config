/*
 * RareGeneAI Nextflow Configuration
 */

manifest {
    name            = 'RareGeneAI'
    author          = 'RareGeneAI Team'
    description     = 'Rare Disease Gene Prioritization Pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

// Default parameters
params {
    outdir    = 'results'
    genome    = 'GRCh38'
    top_n     = 50
    tracedir  = "${params.outdir}/pipeline_info"
}

// Process defaults
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withLabel: 'low_cpu' {
        cpus   = 2
        memory = '4 GB'
    }
    withLabel: 'high_cpu' {
        cpus   = 8
        memory = '16 GB'
    }
    withLabel: 'gpu' {
        cpus   = 4
        memory = '16 GB'
    }
}

// Execution profiles
profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }

    local {
        executor.name = 'local'
        executor.cpus = 8
        executor.memory = '32 GB'
    }

    slurm {
        executor.name = 'slurm'
        executor.queueSize = 50
        process.queue = 'normal'
    }

    cloud {
        executor.name = 'google-batch'
        google.region = 'us-central1'
        google.project = 'raregeneai'
    }

    test {
        params.vcf = 'test/data/test.vcf.gz'
        params.hpo = 'HP:0001250,HP:0002878'
        params.patient_id = 'TEST_001'
    }
}

// Timeline and report
timeline {
    enabled = true
    file    = "${params.tracedir}/timeline.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/report.html"
}
dag {
    enabled = true
    file    = "${params.tracedir}/dag.svg"
}
