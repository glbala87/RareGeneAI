# RareGeneAI Production Environment Variables
# =============================================
# Copy to .env and fill in values before deployment.
# NEVER commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=raregeneai
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=raregeneai

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
RAREGENEAI_SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_MODULE

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RAREGENEAI_ENCRYPTION_KEY=CHANGE_ME_GENERATE_FERNET_KEY

# Comma-separated list of allowed CORS origins
RAREGENEAI_ALLOWED_ORIGINS=https://your-domain.com

# ── API ──────────────────────────────────────────────────────────────────────
RAREGENEAI_ENABLE_DOCS=false
RAREGENEAI_TOKEN_EXPIRE_MINUTES=60

# ── Data Retention ───────────────────────────────────────────────────────────
RAREGENEAI_ANALYSIS_RETENTION_DAYS=2555
RAREGENEAI_AUDIT_RETENTION_DAYS=2190
